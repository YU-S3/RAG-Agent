APP_NAME=Meta Agent
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LLM_CACHE_TTL_SECONDS=600
LLM_DEFAULT_BUDGET_TOKENS=4096
REMOTE_LLM_ENABLED=true
REMOTE_LLM_PROVIDER=openai_compatible
REMOTE_LLM_BASE_URL=<YOUR_REMOTE_LLM_BASE_URL>
REMOTE_LLM_API_KEY=<YOUR_REMOTE_LLM_API_KEY>
REMOTE_LLM_MODEL=<YOUR_REMOTE_LLM_MODEL>
REMOTE_LLM_TIMEOUT_SECONDS=180
SECURITY_ENABLED=false
AUTH_BEARER_TOKEN=change-me
INPUT_BLOCK_PATTERNS=rm -rf|drop table|shutdown|格式化磁盘
RATE_LIMIT_PER_MINUTE=120
RELEASE_CANARY_PERCENT=0
ROLLBACK_ENABLED=false
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_TOP_K=4
RAG_CHUNK_SIZE=400
RAG_CHUNK_OVERLAP=80
RAG_CHUNK_MIN_SIZE=80
RAG_CHUNK_STRATEGY=spacy_auto
RAG_SPACY_MODEL_ZH=zh_core_web_sm
RAG_SPACY_MODEL_EN=en_core_web_sm
RAG_VECTOR_CANDIDATE_TOP_N=64
RAG_VECTOR_CANDIDATE_TOP_N_MEMORY=32
RAG_RERANKER_TYPE=hybrid
RAG_BGE_MODEL_NAME=BAAI/bge-reranker-v2-m3
RAG_BGE_DEVICE=cpu
RAG_BGE_BACKEND=onnxruntime
RAG_BGE_ONNX_PROVIDER=CPUExecutionProvider
RAG_BGE_TOP_N=40
RAG_BGE_TIMEOUT_MS=30000
RAG_BGE_WEIGHT=0.5
RAG_STORE_PROVIDER=auto
QDRANT_URL=<YOUR_QDRANT_URL>
QDRANT_API_KEY=<YOUR_QDRANT_API_KEY>
QDRANT_COLLECTION=meta_agent_chunks
QDRANT_TIMEOUT_SECONDS=6
MEMORY_SESSION_TTL_SECONDS=86400
MEMORY_WINDOW_SIZE=8
DEBUG_LOCAL_ENABLED=true
DOMAIN_CONFIG_ROOT=domains
PROMPT_ROOT=prompts
TOOLS_ROOT=tools
